@{
    Layout = "_Layout";
    ViewData["Title"] = "Quiz Sonucu";
    int score = ViewBag.Score;
    int total = ViewBag.Total;
    var quiz = ViewBag.Quiz as EnglishReadingPlatform.Models.Quiz;
    int pct = total > 0 ? (int)((double)score / total * 100) : 0;
    var emoji = pct >= 80 ? "🏆" : pct >= 60 ? "✅" : pct >= 40 ? "📚" : "💪";
    var label = pct >= 80 ? "Mükemmel!" : pct >= 60 ? "İyi iş!" : pct >= 40 ? "Biraz daha çalış" : "Tekrar dene";
}

<div class="result-card fade-in">
    <div style="font-size:3.5rem; margin-bottom:16px;">@emoji</div>
    <div class="result-score">@score / @total</div>
    <div class="result-label">@label — %@pct doğru</div>

    <div class="progress-bar-wrap" style="margin: 20px 0;">
        <div class="progress-bar-fill" style="width:@pct%"></div>
    </div>

    <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap; margin-top:24px;">
        @if (quiz != null)
        {
            <a href="/Books/Quiz/@quiz.ChapterId" class="btn-secondary">🔄 Tekrar Dene</a>
            <a href="/Books/Read/@quiz.BookId" class="btn-secondary">📖 Okumaya Dön</a>
        }
        <a href="/Books" class="btn-primary" style="width:auto; padding:10px 24px;">📚 Kitaplık</a>
    </div>
</div>
