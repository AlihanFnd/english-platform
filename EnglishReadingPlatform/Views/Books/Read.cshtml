@model EnglishReadingPlatform.Models.Book
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Title + " - Okuma";
    ViewData["Active"] = "books";
    var chapter = ViewBag.CurrentChapter as EnglishReadingPlatform.Models.Chapter;
    int totalChapters = ViewBag.TotalChapters;
    int currentChapter = ViewBag.Chapter;

    // Metni cümlelere böl (C# tarafında da yapıyoruz, JS ile senkronize)
    var content = chapter?.Content ?? "";
    var rawSentences = content
        .Split(new[] { ". ", "! ", "? " }, StringSplitOptions.RemoveEmptyEntries)
        .Select(s => s.Trim())
        .Where(s => s.Length > 2)
        .ToList();
}

<div class="reader-layout fade-in">
    <!-- Header -->
    <div class="reader-header">
        <h1>@Model.Title</h1>
        <div class="chapter-title">@chapter?.Title</div>
        <div class="reader-subinfo">
            <span class="badge badge-purple">@Model.Author</span>
        </div>
    </div>

    <!-- Chapter Nav -->
    <div class="chapter-nav">
        @if (currentChapter > 1)
        {
            <a href="/Books/Read/@Model.Id?chapter=@(currentChapter - 1)" class="btn-secondary">← Önceki</a>
        }
        else { <span></span> }

        <span class="chapter-indicator">Bölüm @currentChapter / @totalChapters</span>

        @if (currentChapter < totalChapters)
        {
            <a href="/Books/Read/@Model.Id?chapter=@(currentChapter + 1)" class="btn-secondary">Sonraki →</a>
        }
        else
        {
            <span class="badge badge-green">✓ Son Bölüm</span>
        }
    </div>

    <!-- Word Type Legend (örnek uygulamadan) -->
    <div class="word-legend fade-in">
        <span class="legend-label">Kelime Türü:</span>
        <span class="legend-item isim">● İsim</span>
        <span class="legend-item fiil">● Fiil</span>
        <span class="legend-item sifat">● Sıfat</span>
        <span class="legend-item zarf">● Zarf</span>
        <span class="legend-item edat">● Edat</span>
        <span class="legend-item baglac">● Bağlaç</span>
        <span class="legend-item zamir">● Zamir</span>
    </div>

    <!-- Analyze Button -->
    <div id="analyzeSection" style="text-align:center; margin-bottom:28px;">
        <button id="analyzeBtn" class="btn-analyze" onclick="analyzeChapter()">
            <span id="analyzeBtnIcon">🔍</span>
            <span id="analyzeBtnText">Cümle Cümle Analiz Et</span>
        </button>
        <p class="analyze-hint">Tüm cümleler Türkçeye çevrilir, kelimelere tıklanabilir hale gelir</p>
    </div>

    <!-- Reading Content — 2 Mod -->
    <!-- MOD 1: Analiz edilmemiş, düz metin -->
    <div id="plainReader" class="reader-content">
        @foreach (var sentence in rawSentences)
        {
            <span class="plain-sentence" onclick="translateSingleSentence(this)" title="Tıkla → bu cümleyi çevir">@sentence. </span>
        }
    </div>

    <!-- MOD 2: Analiz edilmiş — cümle cümle interaktif -->
    <div id="analyzedReader" style="display:none;"></div>

    <!-- Word Tooltip (interactive) -->
    <div id="wordTooltip" class="word-tooltip hidden">
        <div class="wt-header">
            <span id="wtWord" class="wt-word"></span>
            <span id="wtType" class="wt-type"></span>
            <button class="wt-speak" onclick="speakWord()" title="Sesli oku">🔊</button>
        </div>
        <div id="wtTranslation" class="wt-translation">Çevriliyor...</div>
        <button id="wtSave" class="wt-save" onclick="saveCurrentWord()">+ Kelime Listeme Ekle</button>
    </div>

    <!-- Toolbar -->
    <div class="reader-toolbar" style="margin-top:28px;">
        <span class="toolbar-hint">💡 Kelimeye tıkla → çeviri · 📌 Cümlenin altındaki butona tıkla → Türkçe göster</span>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
            <a href="/Books/Quiz/@chapter?.Id" class="btn-secondary">🎯 Quiz</a>
            <a href="/Books/Words" class="btn-secondary">💡 Kelimelerim</a>
            <a href="/Books" class="btn-secondary">← Kitaplık</a>
        </div>
    </div>
</div>

@section Scripts {
<style>
/* ─── Word Type Colors (matching örnek uygulama) ─── */
.word-legend { display:flex; flex-wrap:wrap; align-items:center; gap:10px; margin-bottom:24px; padding:12px 20px; background:var(--glass); border:1px solid var(--glass-border); border-radius:var(--radius); }
.legend-label { font-size:0.72rem; font-weight:800; letter-spacing:0.12em; text-transform:uppercase; color:var(--text-muted); margin-right:6px; }
.legend-item { font-size:0.78rem; font-weight:700; padding:4px 12px; border-radius:99px; cursor:default; }
.legend-item.isim   { background:#dbeafe; color:#1d4ed8; }
.legend-item.fiil   { background:#dcfce7; color:#15803d; }
.legend-item.sifat  { background:#fef3c7; color:#b45309; }
.legend-item.zarf   { background:#ede9fe; color:#7c3aed; }
.legend-item.edat   { background:#fce7f3; color:#be185d; }
.legend-item.baglac { background:#ffedd5; color:#c2410c; }
.legend-item.zamir  { background:#cffafe; color:#0e7490; }

.btn-analyze {
    display:inline-flex; align-items:center; gap:10px;
    padding:14px 32px; border-radius:12px; border:none; cursor:pointer;
    font-size:0.95rem; font-weight:800; letter-spacing:0.04em;
    background:var(--grad-main); color:white;
    box-shadow:0 4px 20px rgba(124,58,237,0.35);
    transition:all 0.2s ease;
}
.btn-analyze:hover { transform:translateY(-2px); box-shadow:0 8px 30px rgba(124,58,237,0.45); }
.btn-analyze:disabled { opacity:0.6; cursor:not-allowed; transform:none; }
.analyze-hint { color:var(--text-muted); font-size:0.78rem; margin-top:8px; }

/* Plain reader — cümleye tıklayınca highlight */
.plain-sentence {
    cursor:pointer; border-radius:4px; transition:background 0.15s;
    padding:1px 2px; line-height:2;
}
.plain-sentence:hover { background:rgba(124,58,237,0.12); color:#c4b5fd; }
.plain-sentence.translating { background:rgba(245,158,11,0.15); color:#fcd34d; }

/* ─── Analyzed Sentence Blocks ─── */
.sentence-block { margin-bottom:36px; }
.sentence-number-row {
    display:flex; align-items:center; gap:14px; margin-bottom:18px;
}
.sentence-num {
    width:34px; height:34px; border-radius:10px; flex-shrink:0;
    background:rgba(124,58,237,0.8); color:white;
    font-size:12px; font-weight:900;
    display:flex; align-items:center; justify-content:center;
}
.sentence-divider { flex:1; height:1px; background:linear-gradient(90deg,rgba(124,58,237,0.4),transparent); }
.sentence-speak-btn {
    width:36px; height:36px; border-radius:50%; border:1px solid var(--glass-border);
    background:var(--glass); color:var(--text-secondary);
    display:flex; align-items:center; justify-content:center;
    cursor:pointer; transition:all 0.2s; font-size:1rem;
}
.sentence-speak-btn:hover { background:rgba(124,58,237,0.2); color:#a78bfa; }

.sentence-words {
    font-size:1.05rem; line-height:2.1;
    color:var(--text-primary); letter-spacing:0.01em;
    margin-bottom:14px; padding:0 4px;
}

/* Interactive word span */
.iword {
    display:inline-block; cursor:pointer; position:relative;
    margin:2px 3px; padding:4px 8px; border-radius:8px;
    border-bottom:2.5px solid rgba(148,163,184,0.3);
    transition:all 0.15s ease; user-select:none;
}
.iword:hover, .iword.active {
    background:rgba(124,58,237,0.18) !important;
    color:#c4b5fd !important;
    border-bottom-color:rgba(124,58,237,0.6) !important;
}
.iword.saved::after {
    content:''; position:absolute; top:-3px; right:-2px;
    width:7px; height:7px; border-radius:50%;
    background:#10b981; border:1.5px solid var(--bg-primary);
}

/* Word type colors */
.iword.isim   { border-bottom-color:#93c5fd; }
.iword.fiil   { border-bottom-color:#86efac; }
.iword.sifat  { border-bottom-color:#fcd34d; }
.iword.zarf   { border-bottom-color:#c4b5fd; }
.iword.edat   { border-bottom-color:#f9a8d4; }
.iword.baglac { border-bottom-color:#fdba74; }
.iword.zamir  { border-bottom-color:#67e8f9; }
.iword.article{ border-bottom-color:#d6d3d1; }

/* Show translation button */
.show-tr-btn {
    display:inline-flex; align-items:center; gap:8px;
    padding:8px 18px; border-radius:10px; border:none; cursor:pointer;
    font-size:0.78rem; font-weight:800; letter-spacing:0.06em;
    transition:all 0.2s ease;
    background:var(--glass); color:var(--text-secondary);
    border:1px solid var(--glass-border);
}
.show-tr-btn:hover { background:rgba(124,58,237,0.15); color:#a78bfa; border-color:rgba(124,58,237,0.3); }
.show-tr-btn.open { background:rgba(124,58,237,0.25); color:#c4b5fd; border-color:rgba(124,58,237,0.5); }

/* Translation reveal box */
.tr-box {
    display:none; margin-top:12px;
    padding:16px 20px;
    border-radius:12px;
    background:rgba(124,58,237,0.06);
    border:1px solid rgba(124,58,237,0.2);
    border-left:4px solid var(--accent-purple);
    animation:fadeIn 0.25s ease;
}
.tr-box.visible { display:block; }
.tr-box p { font-size:1rem; font-weight:500; color:var(--text-secondary); line-height:1.75; font-style:italic; }

/* ─── Word Tooltip ─── */
.word-tooltip {
    position:fixed; z-index:3000;
    width:230px;
    background:#1a1a2e;
    border:1px solid rgba(124,58,237,0.4);
    border-radius:14px; overflow:hidden;
    box-shadow:0 12px 40px rgba(0,0,0,0.6);
    animation:popIn 0.2s cubic-bezier(0.34,1.56,0.64,1);
}
.word-tooltip.hidden { display:none; }
.wt-header {
    display:flex; align-items:center; justify-content:space-between;
    padding:10px 14px 8px;
    background:rgba(124,58,237,0.15);
    border-bottom:1px solid rgba(124,58,237,0.2);
    gap:8px;
}
.wt-word { font-weight:800; font-size:1rem; color:#e2e8f0; }
.wt-type {
    font-size:0.68rem; font-weight:800; text-transform:uppercase;
    padding:2px 8px; border-radius:99px; white-space:nowrap;
    background:rgba(124,58,237,0.25); color:#a78bfa;
    border:1px solid rgba(124,58,237,0.3);
}
.wt-speak { background:none; border:none; cursor:pointer; font-size:1rem; padding:2px 4px; border-radius:6px; transition:all 0.15s; }
.wt-speak:hover { background:rgba(255,255,255,0.1); }
.wt-translation { padding:10px 14px; font-weight:700; font-size:1rem; color:#f8fafc; min-height:42px; }
.wt-save {
    width:100%; padding:9px; border:none; cursor:pointer;
    background:rgba(16,185,129,0.2); color:#6ee7b7;
    font-size:0.78rem; font-weight:700; letter-spacing:0.04em;
    border-top:1px solid rgba(16,185,129,0.2);
    transition:all 0.15s;
}
.wt-save:hover { background:rgba(16,185,129,0.3); }
.wt-save.saved { background:rgba(16,185,129,0.35); color:#a7f3d0; }

/* Single sentence inline translation */
.inline-tr {
    display:inline-block; margin-left:8px;
    padding:3px 10px; border-radius:8px;
    background:rgba(124,58,237,0.1); border:1px solid rgba(124,58,237,0.2);
    color:#a78bfa; font-size:0.82rem; font-style:italic;
    animation:fadeIn 0.3s ease;
}
</style>

<script>
// ─── State ───────────────────────────────────────────────────────────────────
const chapterText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(content));
let savedWordSet = new Set();
let activeWordEl = null;
let currentWordForSave = null;

// ─── Analyze Chapter (Full: sentence + word) ─────────────────────────────────
async function analyzeChapter() {
    const btn = document.getElementById('analyzeBtn');
    const btnText = document.getElementById('analyzeBtnText');
    const btnIcon = document.getElementById('analyzeBtnIcon');
    btn.disabled = true;
    btnIcon.textContent = '⏳';
    btnText.textContent = 'Çevriliyor...';

    try {
        const res = await fetch('/Translate/Analyze', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text: chapterText })
        });
        const data = await res.json();
        if (data.error) throw new Error(data.error);

        renderAnalyzedReader(data.sentences);
        document.getElementById('plainReader').style.display = 'none';
        document.getElementById('analyzedReader').style.display = 'block';
        document.getElementById('analyzeSection').style.display = 'none';
    } catch (err) {
        btnIcon.textContent = '⚠️';
        btnText.textContent = 'Hata: ' + err.message;
        btn.disabled = false;
    }
}

// ─── Render Analyzed Sentences ────────────────────────────────────────────────
function renderAnalyzedReader(sentences) {
    const container = document.getElementById('analyzedReader');
    container.innerHTML = '';

    sentences.forEach((sent, si) => {
        const block = document.createElement('div');
        block.className = 'sentence-block reader-content';
        block.style.cssText = 'background:transparent; border:none; padding:0; margin-bottom:36px;';

        // Numara satırı
        const numRow = document.createElement('div');
        numRow.className = 'sentence-number-row';
        numRow.innerHTML = `
            <div class="sentence-num">${si + 1}</div>
            <div class="sentence-divider"></div>
            <button class="sentence-speak-btn" onclick="speak('${escJs(sent.original)}')" title="Cümleyi dinle">🔊</button>
        `;
        block.appendChild(numRow);

        // Kelimeler
        const wordsDiv = document.createElement('div');
        wordsDiv.className = 'sentence-words';
        sent.words.forEach(w => {
            const span = document.createElement('span');
            const typeClass = mapTypeToClass(w.type);
            span.className = `iword ${typeClass}${savedWordSet.has(w.word.toLowerCase()) ? ' saved' : ''}`;
            span.textContent = w.word;
            span.dataset.word = w.word;
            span.dataset.translation = w.translation;
            span.dataset.type = w.type;
            span.addEventListener('click', (e) => showWordTooltip(e, span));
            wordsDiv.appendChild(span);
            wordsDiv.appendChild(document.createTextNode(' '));
        });
        block.appendChild(wordsDiv);

        // Çeviri butonu
        const trBtn = document.createElement('button');
        trBtn.className = 'show-tr-btn';
        trBtn.innerHTML = `<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg> TÜRKÇE ÇEVİRİYİ GÖSTER`;
        const trBox = document.createElement('div');
        trBox.className = 'tr-box';
        trBox.innerHTML = `<p>${sent.translation}</p>`;

        trBtn.addEventListener('click', () => {
            const open = trBox.classList.toggle('visible');
            trBtn.classList.toggle('open', open);
            trBtn.innerHTML = open
                ? `<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="transform:rotate(180deg)"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg> ÇEVİRİYİ GİZLE`
                : `<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg> TÜRKÇE ÇEVİRİYİ GÖSTER`;
        });

        block.appendChild(trBtn);
        block.appendChild(trBox);
        container.appendChild(block);
    });
}

// ─── Single Sentence Translate (plain reader mode) ───────────────────────────
async function translateSingleSentence(el) {
    if (el.querySelector('.inline-tr')) {
        // Toggle — zaten var, kaldır
        el.querySelector('.inline-tr').remove();
        el.classList.remove('translating');
        return;
    }
    el.classList.add('translating');
    const sentence = el.textContent.trim();
    try {
        const res = await fetch('/Translate/Sentence', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text: sentence })
        });
        const data = await res.json();
        const trSpan = document.createElement('span');
        trSpan.className = 'inline-tr';
        trSpan.textContent = '🇹🇷 ' + (data.translation || '—');
        el.appendChild(trSpan);
    } catch {
        el.classList.remove('translating');
    }
}

// ─── Word Tooltip ─────────────────────────────────────────────────────────────
function showWordTooltip(e, el) {
    e.stopPropagation();
    if (activeWordEl) activeWordEl.classList.remove('active');
    activeWordEl = el;
    el.classList.add('active');

    currentWordForSave = { word: el.dataset.word, translation: el.dataset.translation, type: el.dataset.type };

    const tt = document.getElementById('wordTooltip');
    document.getElementById('wtWord').textContent = el.dataset.word;
    document.getElementById('wtTranslation').textContent = el.dataset.translation || '—';

    // Type badge
    const typeEl = document.getElementById('wtType');
    typeEl.textContent = el.dataset.type || '';
    typeEl.className = 'wt-type ' + mapTypeToClass(el.dataset.type || '');

    // Save btn state
    const saveBtn = document.getElementById('wtSave');
    const alreadySaved = savedWordSet.has(el.dataset.word.toLowerCase());
    saveBtn.textContent = alreadySaved ? '✓ Kaydedildi' : '+ Kelime Listeme Ekle';
    saveBtn.className = 'wt-save' + (alreadySaved ? ' saved' : '');

    // Position tooltip near word
    const rect = el.getBoundingClientRect();
    tt.style.left = Math.min(rect.left, window.innerWidth - 250) + 'px';
    tt.style.top = (rect.top - 120 < 10 ? rect.bottom + 8 : rect.top - 130) + 'px';

    tt.classList.remove('hidden');
}

document.addEventListener('click', (e) => {
    if (!e.target.closest('.word-tooltip') && !e.target.closest('.iword')) {
        document.getElementById('wordTooltip').classList.add('hidden');
        if (activeWordEl) { activeWordEl.classList.remove('active'); activeWordEl = null; }
    }
});

// ─── Save Word ────────────────────────────────────────────────────────────────
async function saveCurrentWord() {
    if (!currentWordForSave) return;
    const w = currentWordForSave;
    try {
        await fetch('/Books/AddWord', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ word: w.word, translation: w.translation, context: w.type })
        });
        savedWordSet.add(w.word.toLowerCase());
        // Mark all instances
        document.querySelectorAll('.iword').forEach(el => {
            if (el.dataset.word === w.word) el.classList.add('saved');
        });
        const saveBtn = document.getElementById('wtSave');
        saveBtn.textContent = '✓ Kaydedildi';
        saveBtn.className = 'wt-save saved';
    } catch (err) { console.error(err); }
}

// ─── Speech ──────────────────────────────────────────────────────────────────
function speak(text) {
    window.speechSynthesis.cancel();
    const u = new SpeechSynthesisUtterance(text);
    u.lang = 'en-US'; u.rate = 0.85;
    window.speechSynthesis.speak(u);
}

function speakWord() {
    if (currentWordForSave?.word) speak(currentWordForSave.word);
}

// ─── Type → CSS Class ────────────────────────────────────────────────────────
function mapTypeToClass(type) {
    const map = {
        'isim': 'isim', 'fiil': 'fiil', 'sıfat': 'sifat', 'zarf': 'zarf',
        'edat': 'edat', 'bağlaç': 'baglac', 'zamir': 'zamir', 'article': 'article',
        'noun': 'isim', 'verb': 'fiil', 'adjective': 'sifat', 'adverb': 'zarf',
        'preposition': 'edat', 'conjunction': 'baglac', 'pronoun': 'zamir'
    };
    return map[type] || 'default';
}

function escJs(str) { return str.replace(/'/g, "\\'").replace(/"/g, '\\"'); }

// Keyboard
document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
        document.getElementById('wordTooltip').classList.add('hidden');
        if (activeWordEl) { activeWordEl.classList.remove('active'); activeWordEl = null; }
    }
});
</script>
}
