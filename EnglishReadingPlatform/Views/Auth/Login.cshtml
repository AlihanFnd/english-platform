@{
    Layout = "_Layout";
    ViewData["Title"] = "Giriş Yap";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-logo">
            <span class="auth-logo-icon">📚</span>
            <h1>ReadEn</h1>
            <p>İngilizce Okuma ve Çeviri Platformu</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">⚠ @ViewBag.Error</div>
        }

        <div class="auth-tabs">
            <div class="auth-tab active">Giriş Yap</div>
            <a href="/Auth/Register" class="auth-tab">Kayıt Ol</a>
        </div>

        <form method="post" action="/Auth/Login">
            <div class="form-group">
                <label class="form-label">E-posta</label>
                <input id="email" name="email" type="email" class="form-input" placeholder="ornek@email.com" required />
            </div>
            <div class="form-group">
                <label class="form-label">Şifre</label>
                <input id="password" name="password" type="password" class="form-input" placeholder="••••••••" required />
            </div>
            <button id="loginBtn" type="submit" class="btn-primary">Giriş Yap →</button>
        </form>

        <div style="text-align:center; margin-top:20px; color:var(--text-muted); font-size:0.8rem;">
            Hesabın yok mu?
            <a href="/Auth/Register" style="color:#a78bfa; font-weight:600;">Kayıt Ol</a>
        </div>
    </div>
</div>
