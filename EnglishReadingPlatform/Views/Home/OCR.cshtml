@model List<EnglishReadingPlatform.Models.OcrRecord>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Metin Tara (OCR)";
    ViewData["Active"] = "ocr";
}

<div class="page-header fade-in">
    <div>
        <h1>📷 Metin Tara</h1>
        <p>Fotoğraf yükle → İngilizce metni dijitalleştir → Çevir</p>
    </div>
</div>

<div style="max-width:780px; margin:0 auto;">
    <!-- Upload Zone -->
    <div class="ocr-upload-zone fade-in" onclick="document.getElementById('imgInput').click()" id="uploadZone">
        <input type="file" id="imgInput" accept="image/*" style="display:none" onchange="handleImageUpload(this)" />
        <div class="ocr-upload-icon" id="uploadIcon">📷</div>
        <h3 style="margin-bottom:8px;">Fotoğraf seç veya buraya sürükle</h3>
        <p style="color:var(--text-muted); font-size:0.875rem;">JPG, PNG, WEBP desteklenir · Tesseract.js ile tanıma yapılır</p>
        <p id="ocrStatus" style="color:var(--accent-cyan); margin-top:12px; font-weight:500;"></p>
    </div>

    <!-- OCR Result -->
    <div id="ocrResultBox" class="ocr-result-box hidden fade-in">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
            <span style="font-weight:600;">📝 Taranan Metin</span>
            <div style="display:flex; gap:8px;">
                <button id="translateAllBtn" onclick="translateAll()" class="btn-secondary">🌐 Tümünü Çevir</button>
                <form method="post" action="/Home/SaveOcr" id="saveOcrForm" style="display:inline;">
                    <input type="hidden" name="text" id="saveOcrText" />
                    <button type="button" id="saveOcrBtn" onclick="saveOcr()" class="btn-secondary">💾 Kaydet</button>
                </form>
            </div>
        </div>
        <textarea id="ocrText" class="ocr-text-area" placeholder="Taranan metin burada görünecek..."></textarea>
    </div>

    <!-- Saved Records -->
    @if (Model.Any())
    {
        <div class="section-title" style="margin-top:40px;"><span>📂</span> Kayıtlı Taramalar</div>
        @foreach (var r in Model)
        {
            <div class="ocr-result-box" style="margin-bottom:16px;">
                <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
                    <span style="color:var(--text-muted); font-size:0.8rem;">@r.ScannedAt.ToString("dd MMMM yyyy HH:mm")</span>
                </div>
                <div style="line-height:1.8; color:var(--text-primary); font-size:0.9rem; max-height:150px; overflow-y:auto;">
                    @foreach (var word in r.ExtractedText.Split(' ', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <span class="word" onclick="translateWord('@word.Trim().Replace("'","\\'")', '@word.Trim().Replace("'","\\'")')">@word</span><text> </text>
                    }
                </div>
            </div>
        }
    }
</div>

@section Scripts {
<script>
async function handleImageUpload(input) {
    if (!input.files[0]) return;
    const file = input.files[0];
    const icon = document.getElementById('uploadIcon');
    icon.textContent = '⏳';
    await runOCR(file);
    icon.textContent = '✅';
}

function saveOcr() {
    const text = document.getElementById('ocrText').value;
    if (!text.trim()) return;
    document.getElementById('saveOcrText').value = text;
    document.getElementById('saveOcrForm').submit();
}

async function translateAll() {
    const text = document.getElementById('ocrText').value;
    if (!text.trim()) return;
    translateWord(text.substring(0, 200), text.substring(0, 200));
}

// Drag and drop
const zone = document.getElementById('uploadZone');
zone.addEventListener('dragover', e => { e.preventDefault(); zone.style.borderColor = 'var(--accent-purple)'; });
zone.addEventListener('dragleave', () => { zone.style.borderColor = ''; });
zone.addEventListener('drop', async e => {
    e.preventDefault();
    zone.style.borderColor = '';
    const file = e.dataTransfer.files[0];
    if (file) await runOCR(file);
});
</script>
}
