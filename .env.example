# ──────────────────────────────────────────────────────────────────
# .env — Docker ortam değişkenleri
# GÜVENLİK: Bu dosyayı asla git'e commit etme!
# .gitignore içine ekle: .env
# ──────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=appuser
POSTGRES_PASSWORD=StrongPass@2026!

# pgAdmin (tarayıcıdan localhost:8080 ile aç)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin123

# JWT Secret Key (en az 32 karakter, güçlü bir değer seç!)
JWT_KEY=EnglishPlatformSuperSecretKey2026_MustBe32Chars!!
